# 站点公开 URL（用于 metadata、Open Graph 等绝对地址；生产示例：https://tengjun.org）
# NEXT_PUBLIC_SITE_URL=https://tengjun.org

# 管理员登录密码（必填）
ADMIN_PASSWORD=your-secret-password

# 登录会话签名密钥，至少 16 个字符（必填）
AUTH_SECRET=your-auth-secret-at-least-16-chars

# Supabase Storage（生产上传必填；本地开发未配置时回退到 /public/uploads）
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# SUPABASE_STORAGE_BUCKET=gallery

# PostgreSQL 连接串（生产环境强烈建议配置，避免 serverless 文件系统不可写）
# 例：postgres://user:password@host:5432/dbname?sslmode=require
# 访客统计与日记共用此库，启动时会自动建 visit_events 表；未配置时仅开发环境可写入 data/analytics-visits.jsonl
# 图片动态会建 moments、moment_media 表；开发环境无库时可写入 data/moments.json
# DATABASE_URL=

# （可选，企业级）Upstash Redis：用于多实例统一的 API 限流；不配置时仍使用单实例内存限流
# https://upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# AI 辅助（后台 Markdown 编辑器，仅管理员可用）。Cursor 会员无对外 API，需自配 OpenAI 兼容服务。
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
