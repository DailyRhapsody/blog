# 站点公开 URL（用于 metadata、Open Graph 等绝对地址；生产示例：https://tengjun.org）
# NEXT_PUBLIC_SITE_URL=https://tengjun.org

# 文章页 /entries 顶栏背景音乐（必填才有音乐+头像旋转；勿把 mp3 提交 Git，见 .gitignore）
# 推荐：在 Supabase Storage 建公开 bucket，上传音频后复制「Public URL」，填到下面：
# NEXT_PUBLIC_ENTRIES_BGM_SRC=https://xxxx.supabase.co/storage/v1/object/public/你的桶/后来的我们.mp3
# 本地开发可把 mp3 放在 public/audio/（已被 gitignore），并写相对站点根路径，例如：
# NEXT_PUBLIC_ENTRIES_BGM_SRC=/audio/houlai-dewomen.mp3

# 管理员登录密码（必填）
ADMIN_PASSWORD=your-secret-password

# 登录会话签名密钥，至少 16 个字符（必填）
AUTH_SECRET=your-auth-secret-at-least-16-chars

# Supabase Storage（生产上传必填；本地开发未配置时回退到 /public/uploads）
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# SUPABASE_STORAGE_BUCKET=gallery

# PostgreSQL 连接串（生产环境强烈建议配置，避免 serverless 文件系统不可写）
# 例：postgres://user:password@host:5432/dbname?sslmode=require
# 访客统计与日记共用此库，启动时会自动建 visit_events 表；未配置时仅开发环境可写入 data/analytics-visits.jsonl
# 图片动态会建 moments、moment_media 表；开发环境无库时可写入 data/moments.json
# DATABASE_URL=

# （可选，企业级）Upstash Redis：用于多实例统一的 API 限流；不配置时仍使用单实例内存限流
# https://upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Notion CMS（日记内容源，替代 PostgreSQL diaries 表）
# 在 https://www.notion.so/my-integrations 创建 internal integration 获取 token
# NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_MOMENTS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_CACHE_TTL=60

# 按需刷新密钥：POST /api/revalidate?secret=<此值> 触发缓存清除
# REVALIDATE_SECRET=your-revalidate-secret

# AI 辅助（后台 Markdown 编辑器，仅管理员可用）。Cursor 会员无对外 API，需自配 OpenAI 兼容服务。
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
